---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SubscribeSection from '../components/SubscribeSection.astro';
---

<Layout title="Support — Svapna" description="Donation-supported. In the spirit of dāna. Buy a coffee, or buy someone else's.">
  <div class="fade-in">
    <SectionHeader num="§ 06" kicker="Dāna" title="Support." sub="If it's been useful, pass it on." />
    <div class="grid grid-cols-1 md:grid-cols-12">
      <div class="md:col-span-7 p-6 sm:p-10 md:p-12 hairline-b md:hairline-r">
        <p class="display text-xl sm:text-2xl md:text-3xl italic leading-relaxed">
          The course, the history, the community — open to anyone. If it's helped, buy us a coffee. Or buy one for someone else.
        </p>
      </div>
      <div class="md:col-span-5 p-6 sm:p-10 md:p-12 hairline-b flex flex-col justify-between gap-10">
        <div>
          <p class="mono text-[10px] uppercase tracking-widest text-neutral-500">Running Total</p>
          <p class="display text-6xl md:text-7xl mt-3 md:mt-4">$ 0</p>
          <p class="mono text-[10px] uppercase tracking-widest text-neutral-500 mt-2">contributed to date</p>
        </div>
        <div class="space-y-3">
          <a
            href="https://buymeacoffee.com/svapna"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full py-4 px-5 md:px-6 mono text-[10px] uppercase tracking-widest active:bg-black active:text-white md:hover:bg-black md:hover:text-white transition-colors text-left flex justify-between items-center"
            style="border: 0.5px solid #000"
          >
            <span>Buy a coffee</span>
            <span>→</span>
          </a>
          <a
            href="https://buymeacoffee.com/svapna?gift=1"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full py-4 px-5 md:px-6 mono text-[10px] uppercase tracking-widest active:bg-black active:text-white md:hover:bg-black md:hover:text-white transition-colors text-left flex justify-between items-center"
            style="border: 0.5px solid #000"
          >
            <span>Buy someone a coffee</span>
            <span>→</span>
          </a>
        </div>
      </div>
      <div class="md:col-span-12 p-6 sm:p-10 md:p-12 hairline-b">
        <p class="mono text-[10px] uppercase tracking-widest text-neutral-500 mb-5 md:mb-6">Where contributions go</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 md:gap-12">
          <div>
            <p class="display text-3xl md:text-4xl">i.</p>
            <p class="mt-2 md:mt-3 text-sm leading-relaxed">Hosting and infrastructure.</p>
          </div>
          <div>
            <p class="display text-3xl md:text-4xl">ii.</p>
            <p class="mt-2 md:mt-3 text-sm leading-relaxed">Audio and video production.</p>
          </div>
          <div>
            <p class="display text-3xl md:text-4xl">iii.</p>
            <p class="mt-2 md:mt-3 text-sm leading-relaxed">Translation into other languages.</p>
          </div>
        </div>
      </div>
    </div>
    <SubscribeSection />
  </div>
</Layout>
