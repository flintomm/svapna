---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import LibraryPitchForm from '../components/react/LibraryPitchForm.jsx';
import ShareButton from '../components/react/ShareButton.jsx';
---

<Layout title="Support — Svapna" description="Donation-supported, in the spirit of dāna. Contributions cover hosting and infrastructure.">
  <div class="fade-in">
    <SectionHeader num="§ 06" kicker="Dāna" title="Support." sub="If it's been useful, pass it on." />

    {/* On Dāna — the why of donation-funding, lifted from the homepage's voice.
        The donate affordance itself is the BMC floating bubble loaded at the
        bottom of this page — no inline donate buttons here. */}
    <div class="grid grid-cols-1 md:grid-cols-12 hairline-b">
      <div class="md:col-span-2 p-5 md:p-8 hairline-b md:hairline-r md:border-b-0">
        <span class="mono text-[9px] md:text-[10px] uppercase tracking-widest text-neutral-500">On Dāna</span>
      </div>
      <div class="md:col-span-10 p-6 sm:p-8 md:p-12 max-w-3xl">
        <p class="display text-2xl md:text-3xl italic leading-relaxed text-neutral-800">
          The work was given to us, and it passes forward.
        </p>
        <p class="mt-5 md:mt-6 text-base leading-loose text-neutral-700">
          Dāna — generosity, in the Sanskrit. Not transaction; circulation. The course, the history, the library, the community — open to anyone. If it has served you, the way to thank the work is to keep it open for the next person.
        </p>
      </div>
    </div>

    {/* Other Ways — non-monetary dāna. Forum-based options come later. */}
    <div class="grid grid-cols-1 md:grid-cols-12 hairline-b">
      <div class="md:col-span-2 p-5 md:p-8 hairline-b md:hairline-r md:border-b-0">
        <span class="mono text-[9px] md:text-[10px] uppercase tracking-widest text-neutral-500">Other Ways</span>
      </div>
      <div class="md:col-span-10 p-6 sm:p-8 md:p-12">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 md:gap-12 max-w-3xl">
          <div>
            <p class="display text-2xl md:text-3xl">i.</p>
            <p class="mt-2 md:mt-3 text-sm leading-relaxed">Write a Library article.</p>
            <LibraryPitchForm client:load />
          </div>
          <div>
            <p class="display text-2xl md:text-3xl">ii.</p>
            <p class="mt-2 md:mt-3 text-sm leading-relaxed">Share the course with someone who would use it.</p>
            <ShareButton client:load />
          </div>
        </div>
      </div>
    </div>

    {/* Who — recipient, what donations fund, and tax status */}
    <div class="grid grid-cols-1 md:grid-cols-12 hairline-b">
      <div class="md:col-span-2 p-5 md:p-8 hairline-b md:hairline-r md:border-b-0">
        <span class="mono text-[9px] md:text-[10px] uppercase tracking-widest text-neutral-500">Who</span>
      </div>
      <div class="md:col-span-10 p-6 sm:p-8 md:p-12 max-w-3xl">
        <p class="text-base leading-loose text-neutral-700">
          Svapna is the work of an independent researcher. Contributions cover hosting and infrastructure. Not a registered nonprofit; contributions are not tax-deductible. <a href="/about/acknowledgments" class="hover:italic transition-all">Acknowledgments</a>.
        </p>
      </div>
    </div>

  </div>

  {/* Buy Me a Coffee floating widget — donate bubble, /support only. */}
  <script
    data-name="BMC-Widget"
    data-cfasync="false"
    src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js"
    data-id="svapna"
    data-description="Support me on Buy me a coffee!"
    data-message="Thank you!"
    data-color="#5F7FFF"
    data-position="Right"
    data-x_margin="18"
    data-y_margin="18"
  ></script>
</Layout>
