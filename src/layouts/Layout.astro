---
import '../styles/global.css';
import { organizationSchema, websiteSchema } from '../lib/seo.js';
import { allLetters } from '../lib/letters.js';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: object | object[];
}

const {
  title = 'Svapna Project - Dream Yoga & Lucid Dreaming',
  description = 'The work, drawing on Mandukya, Tibetan milam, and modern lucid-dreaming science. History, practice, community.',
  ogImage = '/og.jpg',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') + '/' : 'https://svapnaproject.org/';
const canonical = new URL(Astro.url.pathname, siteUrl).href.replace(/\/$/, '') || siteUrl;
const ogImageAbs = new URL(ogImage, siteUrl).href;
// Twitter card image follows ogImage when overridden; falls back to the
// site-wide /twitter-card.jpg only when the default ogImage is in use, so
// the 2:1 Twitter canvas can still ship for the home page while per-page
// 1.91:1 OG cards (e.g. the Door variants) reach the Twitter validator too.
const twitterImageAbs = ogImage === '/og.jpg'
  ? new URL('/twitter-card.jpg', siteUrl).href
  : ogImageAbs;

// Site-wide schema is always emitted; per-page schemas are appended.
const allSchemas = [organizationSchema(siteUrl), websiteSchema(siteUrl)];
if (Array.isArray(jsonLd)) {
  for (const s of jsonLd) if (s) allSchemas.push(s);
} else if (jsonLd) {
  allSchemas.push(jsonLd);
}

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';

const nav = [
  { href: '/', label: 'Home', num: '01' },
  { href: '/history', label: 'History', num: '02' },
  { href: '/curriculum', label: 'Curriculum', num: '03' },
  { href: '/community', label: 'Community', num: '04' },
  { href: '/library', label: 'Library', num: '05' },
  { href: '/support', label: 'Support', num: '06' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
}

// Latest published item shown in the footer strip. Lessons carry no dates,
// so newsletter letters are the canonical "most recent" source. `allLetters`
// is sorted newest-first; if the letters folder is empty the strip is
// omitted entirely.
const latestLetter = allLetters[0] || null;
const latestPublished = latestLetter
  ? {
      title: latestLetter.title,
      date: latestLetter.displayDate,
      href: `/letter/${latestLetter.slug}`,
      label: 'Letter',
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Svapna" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterImageAbs} />
    <link rel="alternate" type="application/rss+xml" title="Svapna" href="/rss.xml" />
    {allSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <script defer src="https://cloud.umami.is/script.js" data-website-id="ce803793-d5c7-4cef-9e9e-bf173d3bc6e1" data-domains="svapnaproject.org"></script>
  </head>
  <body>
    {/* CSS-only mobile menu controller. Toggled by the hamburger label. */}
    <input type="checkbox" id="menu-toggle" aria-hidden="true" />

    <header class="fixed top-0 left-0 right-0 bg-white z-50 hairline-b">
      <div class="flex items-center justify-between px-5 md:px-8 py-3.5 md:py-4">
        <div class="flex items-center gap-3 md:gap-6">
          <a href="/" class="mono text-[10px] uppercase tracking-widest">∴ Svapna</a>
          <div class="mono text-[10px] uppercase tracking-widest text-neutral-400 hidden sm:block">Est. MMXXVI</div>
        </div>

        <nav class="hidden lg:flex items-center gap-6">
          {nav.map(item => (
            <a
              href={item.href}
              class={`mono text-[10px] uppercase tracking-widest transition-colors ${isActive(item.href) ? 'text-black' : 'text-neutral-400 hover:text-black'}`}
            >
              <span class="mr-1.5 opacity-50">{item.num}</span>
              {item.label}
            </a>
          ))}
        </nav>

        <label
          for="menu-toggle"
          class="lg:hidden flex flex-col justify-center items-end gap-1.5 w-10 h-10 -mr-2 cursor-pointer"
          aria-label="Menu"
        >
          <span class="hamburger-line l1"></span>
          <span class="hamburger-line l2"></span>
          <span class="hamburger-line l3"></span>
        </label>
      </div>
    </header>

    <div class="menu-overlay fixed inset-0 z-40 bg-white pt-16 lg:hidden menu-slide overflow-y-auto">
      <div class="hairline-b px-5 py-4">
        <p class="mono text-[10px] uppercase tracking-widest text-neutral-500">Index</p>
      </div>
      {nav.map((item, i) => (
        <a
          href={item.href}
          class="menu-item w-full text-left hairline-b px-5 py-6 flex items-baseline justify-between active:bg-neutral-100 transition-colors"
          style={`animation-delay: ${i * 60}ms`}
        >
          <span class="flex items-baseline gap-5">
            <span class="mono text-[10px] uppercase tracking-widest text-neutral-400 w-6">{item.num}</span>
            <span class={`display text-4xl ${isActive(item.href) ? 'italic' : ''}`}>{item.label}</span>
          </span>
          <span class="mono text-[10px] text-neutral-400">→</span>
        </a>
      ))}
      <div class="px-5 py-8">
        <p class="display text-xl italic text-neutral-500 leading-relaxed">
          "All that we see or seem<br />is but a dream within a dream."
        </p>
        <p class="mono text-[9px] uppercase tracking-widest mt-4 text-neutral-400">— E. A. Poe, 1849</p>
      </div>
    </div>

    <div class="fixed left-0 top-0 bottom-0 w-12 hairline-r z-40 flex-col items-center justify-between py-20 hidden xl:flex">
      <div class="vert-text mono text-[9px] uppercase tracking-[0.3em] text-neutral-500">
        A study in dream and dissolution
      </div>
      <div id="scroll-counter" class="mono text-[9px] text-neutral-400">00</div>
    </div>

    <main class="xl:pl-12 pt-14 md:pt-16">
      <slot />
    </main>

    <footer class="xl:ml-12 hairline-t mt-20 md:mt-32">
      <div class="grid grid-cols-1 md:grid-cols-12">
        <div class="md:col-span-6 p-8 md:p-12 hairline-b md:hairline-r md:border-b-0">
          <p class="display text-2xl md:text-3xl italic leading-tight">
            "All that we see or seem<br />is but a dream within a dream."
          </p>
          <p class="mono text-[10px] uppercase tracking-widest mt-5 md:mt-6 text-neutral-500">— E. A. Poe, 1849</p>
        </div>
        <div class="md:col-span-3 p-8 md:p-12 hairline-b md:hairline-r md:border-b-0">
          <p class="mono text-[10px] uppercase tracking-widest text-neutral-500 mb-4">Index</p>
          <ul class="space-y-2 text-sm">
            <li><a href="/glossary" class="hover:italic transition-all">Glossary</a></li>
            <li><a href="/about/conduct" class="hover:italic transition-all">Code of Conduct</a></li>
            <li><a href="/about/acknowledgments" class="hover:italic transition-all">Acknowledgments</a></li>
            <li><a href="/about/disclaimer" class="hover:italic transition-all">Medical Disclaimer</a></li>
            <li><a href="/about/contact" class="hover:italic transition-all">Contact</a></li>
            <li><a href="/about/privacy" class="hover:italic transition-all">Privacy</a></li>
            <li><a href="/about/terms" class="hover:italic transition-all">Terms</a></li>
          </ul>
        </div>
        <div class="md:col-span-3 p-8 md:p-12">
          <p class="mono text-[10px] uppercase tracking-widest text-neutral-500 mb-4">Dāna</p>
          <p class="text-sm leading-relaxed">
            In the tradition of giving. Take what serves. Pass forward when able.
          </p>
        </div>
      </div>
      <div class="hairline-t px-5 md:px-12 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mono text-[9px] md:text-[10px] uppercase tracking-widest text-neutral-500">
        {latestPublished ? (
          <span class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
            <span>Latest published</span>
            <span class="text-neutral-400">·</span>
            <a href={latestPublished.href} class="text-neutral-700 hover:text-black hover:italic transition-all normal-case tracking-normal">{latestPublished.title}</a>
            <span class="text-neutral-400">—</span>
            <span>{latestPublished.date}</span>
          </span>
        ) : (
          <span>Latest published · forthcoming</span>
        )}
        <a href="/rss.xml" class="flex items-center gap-1.5 hover:text-black transition-colors" aria-label="RSS feed">
          <svg viewBox="0 0 24 24" width="10" height="10" fill="currentColor" aria-hidden="true">
            <path d="M5 3a1 1 0 0 0 0 2 14 14 0 0 1 14 14 1 1 0 1 0 2 0A16 16 0 0 0 5 3zm0 5a1 1 0 0 0 0 2 9 9 0 0 1 9 9 1 1 0 1 0 2 0A11 11 0 0 0 5 8zm1.5 8a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5z"/>
          </svg>
          <span>RSS</span>
        </a>
      </div>
      <div class="hairline-t px-5 md:px-12 py-4 flex flex-col sm:flex-row justify-between gap-2 mono text-[9px] md:text-[10px] uppercase tracking-widest text-neutral-500">
        <span>© 2026 Svapna Project</span>
        <span>Vol. I / Iss. I</span>
        <span>MMXXVI</span>
      </div>
    </footer>

    <script is:inline>
      // Site-wide Umami helper. Tolerates the loader being absent (blocked,
      // offline, or still pending) so call sites never need to guard the call.
      window.trackUmami = function (name) {
        try {
          if (window.umami && typeof window.umami.track === 'function') {
            window.umami.track(name);
          }
        } catch (e) {
          /* swallow — analytics must never break a page */
        }
      };
    </script>

    <script is:inline>
      // Side-rail scroll counter. Tiny enough to inline; runs only on screens
      // wide enough to show the rail.
      (function () {
        var el = document.getElementById('scroll-counter');
        if (!el) return;
        var update = function () {
          var n = Math.min(99, Math.floor(window.scrollY / 20));
          el.textContent = String(n).padStart(2, '0');
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
      })();
    </script>
  </body>
</html>
