---
// ConsentBanner.astro
//
// A bottom-of-page hairline strip that appears on first visit. Persists the
// user's decision to localStorage under `svapna-consent` (values: "accepted"
// | "refused"; absent on first visit).
//
// On "Accept", the same dynamic loader used in consent-loader.js runs
// immediately so the user does not have to refresh to see analytics / BMC
// pick up. On "Refuse", we just hide the banner — the inline loader's
// guard will keep the third-party scripts off this and every future page.
//
// Design notes (matching site voice):
//   - Bottom strip, not a modal. No overlay; page remains readable.
//   - 0.5px hairline-t on top edge, white background, black text.
//   - Mono kicker label, serif body sentence, two text buttons in mono.
//   - Mobile stacks the buttons under the copy.
//
// The component renders a hidden <aside>; the inline script reveals it only
// when there is no stored decision. That avoids any flash for returning
// visitors.
---

<aside
  id="consent-banner"
  class="fixed bottom-0 left-0 right-0 z-50 bg-white hairline-t hidden"
  role="region"
  aria-label="Cookie and storage consent"
  data-consent-banner
>
  <div class="xl:ml-12 grid grid-cols-1 md:grid-cols-12 items-start">
    <div class="md:col-span-2 p-5 md:p-6 hairline-b md:hairline-r md:border-b-0 flex items-start">
      <span class="mono text-[9px] md:text-[10px] uppercase tracking-widest text-neutral-500">
        § Storage
      </span>
    </div>

    <div class="md:col-span-7 p-5 md:p-6 hairline-b md:hairline-r md:border-b-0">
      <p class="text-sm leading-relaxed text-neutral-800">
        Svapna uses two third-party services that set browser storage:
        <span class="italic">Umami</span> for privacy-respecting analytics and
        <span class="italic">Buy Me a Coffee</span> for the donation widget on the support page.
        Neither runs without consent.
      </p>
      <p class="mt-3">
        <a
          href="/about/privacy"
          class="mono text-[10px] uppercase tracking-widest text-neutral-500 hover:text-black hover:italic transition-all"
        >
          Read more →
        </a>
      </p>
    </div>

    <div class="md:col-span-3 p-5 md:p-6 flex flex-col sm:flex-row md:flex-col gap-3 sm:gap-5 md:gap-3">
      <button
        type="button"
        data-consent-accept
        class="mono text-[10px] uppercase tracking-widest text-left text-black hover:italic transition-all"
      >
        → Accept
      </button>
      <button
        type="button"
        data-consent-refuse
        class="mono text-[10px] uppercase tracking-widest text-left text-neutral-500 hover:text-black hover:italic transition-all"
      >
        → Refuse
      </button>
    </div>
  </div>
</aside>

<script is:inline>
  // Banner controller. Runs once on every page; cheap and idempotent.
  // Pairs with the early-firing consent-loader in Layout.astro that injects
  // Umami / BMC if the user has already accepted on a previous visit.
  (function () {
    var KEY = 'svapna-consent';
    var banner = document.getElementById('consent-banner');
    if (!banner) return;

    var stored;
    try { stored = localStorage.getItem(KEY); } catch (e) { stored = null; }

    // Already decided — never bother them again.
    if (stored === 'accepted' || stored === 'refused') return;

    // Show the banner. Eurozone heuristic: we always block-by-default and
    // always show, so the timezone read is purely informational here. We
    // expose it as a data attribute so the operator can inspect during QA.
    try {
      var tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
      if (/^Europe\//.test(tz)) banner.setAttribute('data-eu-heuristic', 'true');
    } catch (e) { /* noop */ }

    banner.classList.remove('hidden');

    function inject(src, attrs) {
      var s = document.createElement('script');
      s.src = src;
      if (attrs) for (var k in attrs) s.setAttribute(k, attrs[k]);
      document.body.appendChild(s);
    }

    function loadThirdParties() {
      // Umami — site-wide.
      inject('https://cloud.umami.is/script.js', {
        defer: '',
        'data-website-id': 'ce803793-d5c7-4cef-9e9e-bf173d3bc6e1',
        'data-domains': 'svapnaproject.org',
      });
      // BMC — only meaningful on /support, but the widget itself decides
      // whether to render. Loading it elsewhere is harmless.
      if (location.pathname.replace(/\/+$/, '') === '/support') {
        inject('https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js', {
          'data-name': 'BMC-Widget',
          'data-cfasync': 'false',
          'data-id': 'svapna',
          'data-description': 'Support the Svapna project on Buy Me a Coffee.',
          'data-message': 'Thank you!',
          'data-color': '#5F7FFF',
          'data-position': 'Right',
          'data-x_margin': '18',
          'data-y_margin': '18',
        });
      }
    }

    function dismiss() { banner.classList.add('hidden'); }

    var acceptBtn = banner.querySelector('[data-consent-accept]');
    var refuseBtn = banner.querySelector('[data-consent-refuse]');

    if (acceptBtn) acceptBtn.addEventListener('click', function () {
      try { localStorage.setItem(KEY, 'accepted'); } catch (e) {}
      loadThirdParties();
      dismiss();
    });

    if (refuseBtn) refuseBtn.addEventListener('click', function () {
      try { localStorage.setItem(KEY, 'refused'); } catch (e) {}
      dismiss();
    });
  })();
</script>
